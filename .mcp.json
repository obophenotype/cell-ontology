{
  "mcpServers": {
    "Asta_semanticscholar": {
      "type": "http",
      "url": "https://asta-tools.allen.ai/mcp/v1",
      "headers": { "x-api-key": "${ASTA_API_KEY}" },
      "tools": ["*"]
    },
    "artl-mcp": {
      "type": "stdio",
      "command": "uv",
      "args": ["tool", "run", "artl-mcp"]
    }
  }
}