        <owl:annotatedTarget>A vesicle formed from the lens pit of the embryo, developing into the crystalline lens. [TFD][VHOG]</owl:annotatedTarget>
        <oboInOwl:date_retrieved>2012-09-17</oboInOwl:date_retrieved>
        <oboInOwl:external_class>VHOG:0001163</oboInOwl:external_class>
