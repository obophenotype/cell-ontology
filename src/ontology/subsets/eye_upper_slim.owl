        <oboInOwl:hasDbXref>ZFA:0001135</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>neuronames:1365</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>neural primordium</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>presumptive central nervous system</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>tubus neuralis</oboInOwl:hasRelatedSynonym>
