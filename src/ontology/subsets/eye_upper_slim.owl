            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A cell present in the developing CNS. Functions as both a precursor cell and as a scaffold to support neuronal migration.</obo:IAO_0000115>
        <oboInOwl:hasNarrowSynonym>forebrain radial glial cell</oboInOwl:hasNarrowSynonym>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/cl#cellxgene_subset"/>
        <rdfs:comment>Unlike that of mammals, the brain of adult teleost fish exhibits an intense and widespread neurogenic activity as a result of the persistence of
radial glial cells acting as neural progenitors throughout life.</rdfs:comment>
        <rdfs:label>radial glial cell</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/CL_0000681"/>
