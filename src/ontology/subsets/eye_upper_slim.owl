        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/uberon/core#extends_fibers_into"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>X extends_fibers into Y iff there exists some neuron (N) and N has_soma_location X and N &apos;has synaptic IO in region&apos; some Y</owl:annotatedTarget>
        <oboInOwl:hasDbXref>https://orcid.org/0000-0002-7073-9172</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/uberon/core#filtered_through -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/uberon/core#filtered_through">
        <obo:IAO_0000115>Relationship between a fluid and a material entity, where the fluid is the output of a realization of a filtration role that inheres in the material entity.</obo:IAO_0000115>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:id>filtered_through</oboInOwl:id>
        <rdfs:comment>Relationship between a fluid and a filtration barrier, where the portion of fluid arises as a transformation of another portion of fluid on the other side of the barrier, with larger particles removed</rdfs:comment>
        <rdfs:label>filtered through</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/uberon/core#indirectly_supplies -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/uberon/core#indirectly_supplies">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/RO_0002569"/>
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/RO_0002178"/>
        </owl:propertyChainAxiom>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/RO_0002569"/>
            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/uberon/core#indirectly_supplies"/>
        </owl:propertyChainAxiom>
        <obo:IAO_0000115>a indirectly_supplies s iff a has a branch and the branch supplies or indirectly supplies s.</obo:IAO_0000115>
        <obo:IAO_0000116>add to RO</obo:IAO_0000116>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:id>indirectly_supplies</oboInOwl:id>
        <rdfs:label>indirectly_supplies</rdfs:label>
    </owl:ObjectProperty>
    


