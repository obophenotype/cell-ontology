   has_part some (
      ‘pre-synaptic membrane ; GO:0042734’ that part_of some ( 
	‘synapse ; GO:0045202’ that has_part some (
	   ‘post-synaptic membrane ; GO:0045211’ that part_of some N2))))</rdfs:comment>
        <rdfs:label xml:lang="en">synapsed to</rdfs:label>
    </owl:ObjectProperty>
    


