        <oboInOwl:hasDbXref>Wikipedia:Face</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>galen:Face</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>facia/facies</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>visage</oboInOwl:hasRelatedSynonym>
