        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#vertebrate_core"/>
        <rdfs:comment>The lens is avascular and nourished by diffusion from the aqueous and vitreous humors.</rdfs:comment>
        <rdfs:label>lens of camera-type eye</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000965"/>
