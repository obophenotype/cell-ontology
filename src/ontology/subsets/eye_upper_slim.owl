    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0005253">
        <rdfs:subClassOf rdf:nodeID="genid2276"/>
        <obo:IAO_0000115>Portion of primordial embryonic connective tissue of the developing head, consisting of mesenchymal cells supported in interlaminar jelly, that derive mostly from the mesoderm and contribute to head connective tissue, bone and musculature in conjunction with cranial neural crest cells.</obo:IAO_0000115>
