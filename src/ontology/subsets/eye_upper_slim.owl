    <!-- http://purl.obolibrary.org/obo/CL_0000573 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/CL_0000573">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/CL_0010009"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002202"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CL_0002672"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>One of the two photoreceptor cell types in the vertebrate retina. In cones the photopigment is in invaginations of the cell membrane of the outer segment. Cones are less sensitive to light than rods, but they provide vision with higher spatial and temporal acuity, and the combination of signals from cones with different pigments allows color vision.</obo:IAO_0000115>
        <obo:RO_0002175 rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_9606"/>
        <oboInOwl:hasDbXref>BTO:0001036</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>CALOHA:TS-0866</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:67748</oboInOwl:hasDbXref>
        <oboInOwl:hasRelatedSynonym>cone</oboInOwl:hasRelatedSynonym>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/cl#cellxgene_subset"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#human_reference_atlas"/>
        <rdfs:label>retinal cone cell</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/CL_0000573"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>One of the two photoreceptor cell types in the vertebrate retina. In cones the photopigment is in invaginations of the cell membrane of the outer segment. Cones are less sensitive to light than rods, but they provide vision with higher spatial and temporal acuity, and the combination of signals from cones with different pigments allows color vision.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>MESH:D017949</oboInOwl:hasDbXref>
