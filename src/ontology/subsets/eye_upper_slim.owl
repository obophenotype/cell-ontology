    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001782"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A monolayer of pigmented epithelium covering the neural retina; develops from the outer of the two layers of the optic cup[ZFA]. the pigmented cell layer just outside the neurosensory retina that nourishes retinal visual cells, and is firmly attached to the underlying choroid and overlying retinal visual cells[WP].</owl:annotatedTarget>
        <oboInOwl:hasDbXref>Wikipedia:Retinal_pigment_epithelium</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFIN:curator</oboInOwl:hasDbXref>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001782"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/UBPROP_0000001"/>
        <owl:annotatedTarget>A monolayer of pigmented epithelium covering the neural retina; develops from the outer of the two layers of the optic cup. Kimmel et al, 1995.[TAO]</owl:annotatedTarget>
        <oboInOwl:date_retrieved>2012-08-14</oboInOwl:date_retrieved>
