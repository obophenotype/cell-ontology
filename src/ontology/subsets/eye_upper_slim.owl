                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/GO_0001677"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>The process preceding formation of the peptide bond between the first two amino acids of a protein. This includes the formation of a complex of the ribosome, mRNA or circRNA, and an initiation complex that contains the first aminoacyl-tRNA.</obo:IAO_0000115>
        <oboInOwl:hasAlternativeId>GO:0006440</oboInOwl:hasAlternativeId>
        <oboInOwl:hasAlternativeId>GO:0006454</oboInOwl:hasAlternativeId>
        <oboInOwl:hasBroadSynonym>biopolymerisation</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasBroadSynonym>biopolymerization</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasBroadSynonym>protein synthesis initiation</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasExactSynonym>translation initiation</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>biological_process</oboInOwl:hasOBONamespace>
        <oboInOwl:id>GO:0006413</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/go#goslim_yeast"/>
        <rdfs:label>translational initiation</rdfs:label>
    </owl:Class>
    <owl:Axiom>
