    <!-- http://purl.obolibrary.org/obo/UBERON_0006268 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0006268">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0005423"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002160"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_7711"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf rdf:nodeID="genid2358"/>
        <obo:IAO_0000115>A midline cellular cord formed from the migration of mesenchymal cells from the primitive knot.</obo:IAO_0000115>
        <oboInOwl:hasDbXref>EHDAA2:0001279</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>EHDAA:224</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>EMAPA:16102</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:293135</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>NCIT:C34232</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C1518430</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VHOG:0001213</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>chordamesoderm</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>presumptive notochord</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>UBERON:0006268</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#emapa_ehdaa2"/>
        <rdfs:comment>The notochordal process grows cranially until it reaches the prechordal plate, the future site of the mouth. In this area the ectoderm is attached directly to the endoderm without intervening mesoderm. This area is known as the oropharyngeal membrane, and it will break down to become the mouth. At the other end of the primitive streak the ectoderm is also fused directly to the endoderm; this is known as the cloacal membrane (proctodeum), or primordial anus.</rdfs:comment>
        <rdfs:label>notochordal process</rdfs:label>
    </owl:Class>
    <owl:Restriction rdf:nodeID="genid2358">
        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002202"/>
        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000924"/>
    </owl:Restriction>
