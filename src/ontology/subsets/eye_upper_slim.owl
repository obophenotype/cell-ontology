    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002388 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002388">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0002387"/>
