    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001782"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/UBPROP_0000001"/>
        <owl:annotatedTarget>The monolayer of pigmented epithelium covering the neural retina.[AAO]</owl:annotatedTarget>
        <oboInOwl:date_retrieved>2012-06-20</oboInOwl:date_retrieved>
        <oboInOwl:external_class>AAO:0011096</oboInOwl:external_class>
