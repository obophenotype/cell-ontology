        <oboInOwl:hasDbXref>FBbt:00005106</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:54527</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VHOG:0001483</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>WBbt:0003679</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>nerve cell</oboInOwl:hasExactSynonym>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/cl#cellxgene_subset"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/cl#general_cell_types_upper_slim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#human_reference_atlas"/>
        <rdfs:comment>These cells are also reportedly CD4-negative and CD200-positive. They are also capable of producing CD40L and IFN-gamma.</rdfs:comment>
        <rdfs:label>neuron</rdfs:label>
        <foaf:depiction rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://www.swissbiopics.org/api/image/Neuron_cells.svg</foaf:depiction>
    </owl:Class>
