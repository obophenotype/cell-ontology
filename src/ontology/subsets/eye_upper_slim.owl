            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A structure that lies outside the plasma membrane and surrounds the entire cell or cells. This does not include the periplasmic space.</obo:IAO_0000115>
        <oboInOwl:hasOBONamespace>cellular_component</oboInOwl:hasOBONamespace>
        <oboInOwl:id>GO:0030312</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/go#goslim_chembl"/>
