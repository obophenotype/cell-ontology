        </rdfs:subClassOf>
        <obo:IAO_0000115>A muscle tissue that is associated with soft internal organs (viscera).</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-6677-8489"/>
        <terms:date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-02-16T10:17:46Z</terms:date>
