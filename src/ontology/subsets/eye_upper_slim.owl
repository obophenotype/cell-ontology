            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>The basic cellular unit of nervous tissue. Each neuron consists of a body, an axon, and dendrites. Their purpose is to receive, conduct, and transmit impulses in the nervous system.</obo:IAO_0000115>
        <obo:RO_0002175 rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_9606"/>
        <oboInOwl:hasDbXref>BTO:0000938</oboInOwl:hasDbXref>
