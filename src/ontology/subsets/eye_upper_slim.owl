                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/GO_0010467"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
