        <owl:annotatedProperty rdf:resource="http://www.geneontology.org/formats/oboInOwl#hasRelatedSynonym"/>
        <owl:annotatedTarget>neural crest material</owl:annotatedTarget>
        <oboInOwl:hasDbXref>VHOG:0000057</oboInOwl:hasDbXref>
    </owl:Axiom>
    


