        <rdfs:label>aqueous humor of eyeball</rdfs:label>
        <foaf:depiction rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://upload.wikimedia.org/wikipedia/commons/1/1e/Schematic_diagram_of_the_human_eye_en.svg</foaf:depiction>
    </owl:Class>
