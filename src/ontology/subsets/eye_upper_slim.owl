        <oboInOwl:hasDbXref>EHDAA:7860</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>EMAPA:16096</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:87656</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>NCIT:C34309</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C1515087</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>Wikipedia:External_ectoderm</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>surface (external) ectoderm</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>surface ectoderm</oboInOwl:hasExactSynonym>
