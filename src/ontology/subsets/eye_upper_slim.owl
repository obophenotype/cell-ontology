    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001049"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/UBPROP_0000001"/>
        <owl:annotatedTarget>The dorsal tubular structure in the vertebrate embryo that develops into the brain and spinal cord. [TFD][VHOG]</owl:annotatedTarget>
        <oboInOwl:date_retrieved>2012-09-17</oboInOwl:date_retrieved>
        <oboInOwl:external_class>VHOG:0000307</oboInOwl:external_class>
