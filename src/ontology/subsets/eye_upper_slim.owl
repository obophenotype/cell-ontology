    <!-- http://purl.obolibrary.org/obo/cl#has_high_plasma_membrane_amount -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/cl#has_high_plasma_membrane_amount">
        <obo:IAO_0000115>OBSOLETE A relation between a cell and molecule or complex such that every instance of the cell has a high number of instances of that molecule expressed on the cell surface. For the formal definition, see Masci et al (PMID:19243617).</obo:IAO_0000115>
        <obo:IAO_0000233 rdf:resource="https://github.com/obophenotype/cell-ontology/issues/1481"/>
        <obo:IAO_0100001 rdf:resource="http://purl.obolibrary.org/obo/RO_0015015"/>
        <rdfs:label>obsolete has_high_plasma_membrane_amount</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:ObjectProperty>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/cl#has_high_plasma_membrane_amount"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>OBSOLETE A relation between a cell and molecule or complex such that every instance of the cell has a high number of instances of that molecule expressed on the cell surface. For the formal definition, see Masci et al (PMID:19243617).</owl:annotatedTarget>
        <oboInOwl:hasDbXref>PMID:19243617</oboInOwl:hasDbXref>
    </owl:Axiom>
    


