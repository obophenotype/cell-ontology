    <!-- http://purl.obolibrary.org/obo/RO_0002387 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002387">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0002384"/>
