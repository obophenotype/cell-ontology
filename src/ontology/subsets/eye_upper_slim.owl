        <oboInOwl:hasDbXref>XAO:0000183</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0005563</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>scleral capsule</oboInOwl:hasRelatedSynonym>
