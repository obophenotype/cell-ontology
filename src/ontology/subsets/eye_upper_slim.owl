        <rdfs:label>face</rdfs:label>
        <foaf:depiction rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://upload.wikimedia.org/wikipedia/commons/5/55/Mona_Lisa_headcrop.jpg</foaf:depiction>
    </owl:Class>
