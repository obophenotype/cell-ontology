        <oboInOwl:hasDbXref>VHOG:0001245</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>XAO:0000172</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0005145</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>galen:Muscle</oboInOwl:hasDbXref>
