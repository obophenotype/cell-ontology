            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A pigment cell derived from the neural crest. Contains melanin-filled pigment granules, which gives a brown to black appearance.</obo:IAO_0000115>
        <obo:RO_0002175 rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_9606"/>
        <oboInOwl:hasDbXref>BTO:0000847</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>CALOHA:TS-0613</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:70545</oboInOwl:hasDbXref>
