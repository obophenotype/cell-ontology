    <!-- http://purl.obolibrary.org/obo/UBERON_0004128 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0004128">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000465"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000479"/>
        <rdfs:subClassOf rdf:nodeID="genid2153"/>
        <rdfs:subClassOf rdf:nodeID="genid2155"/>
