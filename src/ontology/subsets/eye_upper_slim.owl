        <oboInOwl:hasDbXref>FMA:66768</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>WBbt:0003672</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>epitheliocyte</oboInOwl:hasExactSynonym>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/cl#cellxgene_subset"/>
