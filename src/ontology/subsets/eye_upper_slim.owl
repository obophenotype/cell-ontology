        <oboInOwl:hasDbXref>MESH:D041981</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>NCIT:C34082</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>TAO:0000112</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>TGMA:0001819</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C0017189</oboInOwl:hasDbXref>
