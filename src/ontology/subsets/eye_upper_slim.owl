        <oboInOwl:hasExactSynonym>camera-type eye lens</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>eye lens</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>lens</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>lens crystallina</oboInOwl:hasExactSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>crystalline lens</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>lenses</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>ocular lens</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>UBERON:0000965</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#human_reference_atlas"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#pheno_slim"/>
