        <oboInOwl:hasDbXref>Wikipedia:Germ_layer</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>XAO:0003011</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0001122</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>germinal layer</oboInOwl:hasExactSynonym>
        <oboInOwl:hasNarrowSynonym>primary germ layer</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>embryonic germ layer</oboInOwl:hasRelatedSynonym>
