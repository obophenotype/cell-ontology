        <oboInOwl:hasDbXref>ZFA:0000050</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>evagination</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>eye vesicle</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>ocular vesicle</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>optic vesicles</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>UBERON:0004128</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#pheno_slim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#vertebrate_core"/>
        <rdfs:comment>Genes: Six3, Pax6, Rx1 are expressed together in the tip of the neural plate [ISBN:9780878932504 &quot;Developmental Biology&quot;]. Development notes: During subsequent develop- ment, the optic vesicle invaginates and becomes a two-layered structure with an inner neural retina and outer retinal pigment epithelium. As soon as the developing optic vesicle makes contact with the overlying ectoderm, it induces the ectoderm to thicken and form the lens placode [PMID:16496288]</rdfs:comment>
        <rdfs:label>optic vesicle</rdfs:label>
        <foaf:depiction rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">http://upload.wikimedia.org/wikipedia/commons/e/e0/Gray863.png</foaf:depiction>
    </owl:Class>
