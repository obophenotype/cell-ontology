            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>One of the two photoreceptor cell types of the vertebrate retina. In rods the photopigment is in stacks of membranous disks separate from the outer cell membrane. Rods are more sensitive to light than cones, but rod mediated vision has less spatial and temporal resolution than cone vision.</obo:IAO_0000115>
        <obo:RO_0002175 rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_9606"/>
        <oboInOwl:hasDbXref>BTO:0001024</oboInOwl:hasDbXref>
