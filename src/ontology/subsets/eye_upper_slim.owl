        <oboInOwl:hasDbXref>BilaDO:0000008</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>EFO:0001296</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FBdv:00005317</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>HsapDv:0000010</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MmusDv:0000013</oboInOwl:hasDbXref>
