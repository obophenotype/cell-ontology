        </rdfs:subClassOf>
        <obo:IAO_0000115>The ciliary muscle is a ring of smooth muscle in the middle layer of the eye that controls the eye&apos;s accommodation for viewing objects at varying distances and regulates the flow of aqueous humour through Schlemm&apos;s canal. [WP,unvetted].</obo:IAO_0000115>
        <obo:RO_0002175 rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_9606"/>
        <oboInOwl:hasDbXref>BTO:0000654</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>EMAPA:35240</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>FMA:49151</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>MA:0001269</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>NCIT:C32315</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>SCTID:280862009</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C0559230</oboInOwl:hasDbXref>
