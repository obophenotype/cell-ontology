        <oboInOwl:hasDbXref>Wikipedia:Neural_fold</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>XAO:0004087</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>neuronames:1364</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>medullary fold</oboInOwl:hasExactSynonym>
