        <oboInOwl:hasDbXref>TAO:0001238</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>UMLS:C0022077</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VHOG:0000101</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>Wikipedia:Iris_(anatomy)</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>XAO:0000185</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0001238</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>anterior uvea</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>irides</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>irises</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>UBERON:0001769</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#efo_slim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#human_reference_atlas"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#pheno_slim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#uberon_slim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#vertebrate_core"/>
        <rdfs:label>iris</rdfs:label>
