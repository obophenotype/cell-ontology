        <oboInOwl:id>has_output</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/valid_for_go_annotation_extension"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/valid_for_go_ontology"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/valid_for_gocam"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/ro/subsets#ro-eco"/>
        <oboInOwl:shorthand>has_output</oboInOwl:shorthand>
        <rdfs:label>has output</rdfs:label>
        <rdfs:label xml:lang="en">has output</rdfs:label>
        <rdfs:seeAlso rdf:datatype="http://www.w3.org/2001/XMLSchema#anyURI">https://wiki.geneontology.org/Has_output</rdfs:seeAlso>
    </owl:ObjectProperty>
    


    <!-- http://purl.obolibrary.org/obo/RO_0002252 -->

    <owl:ObjectProperty rdf:about="http://purl.obolibrary.org/obo/RO_0002252">
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0002170"/>
        <rdfs:subPropertyOf rdf:resource="http://purl.obolibrary.org/obo/RO_0002375"/>
        <owl:inverseOf rdf:resource="http://purl.obolibrary.org/obo/RO_0002253"/>
        <obo:IAO_0000112>In the tree T depicted in https://oborel.github.io/obo-relations/branching_part_of.png, B1 is connecting branch of S, and B1-1 as a connecting branch of B1.</obo:IAO_0000112>
        <obo:IAO_0000115>b connecting-branch-of s iff b is connected to s, and there exists some tree-like structure t such that the mereological sum of b plus s is either the same as t or a branching-part-of t.</obo:IAO_0000115>
        <obo:RO_0004036 rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
        <oboInOwl:hasDbXref>RO:0002252</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:id>connecting_branch_of</oboInOwl:id>
        <oboInOwl:shorthand>connecting_branch_of</oboInOwl:shorthand>
        <rdfs:label>connecting branch of</rdfs:label>
        <rdfs:seeAlso rdf:resource="https://github.com/obophenotype/uberon/issues/2212"/>
    </owl:ObjectProperty>
    


