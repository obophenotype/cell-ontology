    <!-- http://purl.obolibrary.org/obo/UBERON_0000965 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0000965">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0005389"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000050"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001801"/>
            </owl:Restriction>
