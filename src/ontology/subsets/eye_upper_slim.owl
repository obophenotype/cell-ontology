        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002160"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_6072"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A layer of cells produced during the process of gastrulation during the early development of the animal embryo, which is distinct from other such layers of cells, as an early step of cell differentiation. The three types of germ layers are the endoderm, ectoderm, and mesoderm.</obo:IAO_0000115>
        <obo:UBPROP_0000003>The Bilateria are triploblastic (with true endoderm, mesoderm, and ectoderm) (...).[well established][VHOG]</obo:UBPROP_0000003>
        <oboInOwl:hasBroadSynonym>embryonic tissue</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasDbXref>AAO:0000480</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>BILA:0000035</oboInOwl:hasDbXref>
