    <!-- http://purl.obolibrary.org/obo/GO_0023052 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/GO_0023052">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0050789"/>
        <obo:IAO_0000115>The entirety of a process in which information is transmitted within a biological system. This process begins with an active signal and ends when a cellular response has been triggered.</obo:IAO_0000115>
        <oboInOwl:created_by>jl</oboInOwl:created_by>
        <oboInOwl:creation_date>2010-02-16T09:30:50Z</oboInOwl:creation_date>
