    <!-- http://purl.obolibrary.org/obo/GO_0048731 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/GO_0048731">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0048856"/>
        <rdfs:subClassOf>
            <owl:Restriction>
