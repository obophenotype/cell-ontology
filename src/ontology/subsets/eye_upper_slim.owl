    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001049"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/UBPROP_0000003"/>
        <owl:annotatedTarget>(...) at some stage of its development, every chordate exhibits five uniquely derived characters or synapomorphies of the group: (...) (4) a single, tubular nerve cord that is located dorsal to the notochord (...).[well established][VHOG]</owl:annotatedTarget>
        <oboInOwl:date_retrieved>2012-09-17</oboInOwl:date_retrieved>
        <oboInOwl:external_class>VHOG:0000307</oboInOwl:external_class>
        <oboInOwl:ontology>VHOG</oboInOwl:ontology>
