        <oboInOwl:hasDbXref>ZFA:0000112</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>galen:AlimentaryTract</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>digestive tube</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>enteric tract</oboInOwl:hasExactSynonym>
        <oboInOwl:hasNarrowSynonym>alimentary canal</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasNarrowSynonym>alimentary tract</oboInOwl:hasNarrowSynonym>
        <oboInOwl:hasOBONamespace>uberon</oboInOwl:hasOBONamespace>
        <oboInOwl:hasRelatedSynonym>digestive canal</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>gut tube</oboInOwl:hasRelatedSynonym>
        <oboInOwl:id>UBERON:0001555</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#human_reference_atlas"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#uberon_slim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#vertebrate_core"/>
        <rdfs:label>digestive tract</rdfs:label>
    </owl:Class>
