        <oboInOwl:hasDbXref>http://en.wikipedia.org/wiki/Mesenchymal_stem_cell</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>http://www.copewithcytokines.de/cope.cgi?key=mesenchymal%20stem%20cells</oboInOwl:hasDbXref>
    </owl:Axiom>
