    <!-- http://purl.obolibrary.org/obo/UBERON_0001136 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0001136">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001062"/>
        <rdfs:subClassOf rdf:nodeID="genid1557"/>
        <obo:IAO_0000115>Simple squamous epithelium of mesodermal origin which lines serous membranes. Examples: mesothelium of pleura, mesothelium of peritoneum[FMA]. Wikipedia: The mesothelium is a membrane that forms the lining of several body cavities: the pleura (thoracal cavity), peritoneum (abdominal cavity including the mesentery) and pericardium (heart sac). Mesothelial tissue also surrounds the male internal reproductive organs (the tunica vaginalis testis) and covers the internal reproductive organs of women (the tunica serosa uteri).</obo:IAO_0000115>
        <oboInOwl:hasDbXref>AEO:0000111</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>BTO:0002422</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>CALOHA:TS-1183</oboInOwl:hasDbXref>
