is_a: UBERON:0000922 ! embryo
is_a: UBERON:0001062 ! anatomical entity
relationship: develops_from UBERON:0007010 ! cleaving embryo
property_value: depiction "http://upload.wikimedia.org/wikipedia/commons/c/c6/Blastulation.png" xsd:anyURI
property_value: editor_note "TODO - check relationship with epiblast. Note in FMA this is not a subclass of embryo, but in uberon embryo is the whole organism from zygote onwards and thus includes the blastula" xsd:string

