id: UBERON:0001796
name: aqueous humor of eyeball
namespace: uberon
def: "A thick watery refractive medium that fills the space between the lens and the cornea[WP]." [Wikipedia:Aqueous_humor]
subset: pheno_slim
subset: uberon_slim
subset: vertebrate_core
